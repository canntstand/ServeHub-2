map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 8080;
    server_name _;

    location /stub_status {
        stub_status;
        allow 172.16.0.0/12;
        allow 10.8.0.0/24;
        allow 127.0.0.1;
        deny all;
    }

    location = /health-check {
        proxy_pass http://10.8.0.2:8080/health-check; 
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    location = /vps-health-check {
        return 200 "Server is alive";
        add_header Content-Type text/plain;
    }
}

server {
    listen 80;
    server_name ${SYNAPSE_SERVER_NAME};

    allow 127.0.0.1;
    allow 172.16.0.0/12;
    allow 10.8.0.0/24;
    deny all;

    location / {
        return 301 https://${SYNAPSE_SERVER_NAME}$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name gatus.${SYNAPSE_SERVER_NAME};

    ssl_certificate /etc/letsencrypt/live/${SYNAPSE_SERVER_NAME}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${SYNAPSE_SERVER_NAME}/privkey.pem;

    client_max_body_size 2G;
    add_header Strict-Transport-Security "max-age=15552000; includeSubDomains; preload" always;
    set_real_ip_from 172.16.0.0/12;
    set_real_ip_from 10.0.0.0/8;
    set_real_ip_from 127.0.0.1;
    real_ip_recursive on;

    allow 127.0.0.1;
    allow 172.16.0.0/12;
    allow 10.8.0.0/24;
    deny all;

    location / {
        proxy_pass http://127.0.0.1:51822; 
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

