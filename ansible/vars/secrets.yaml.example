# ==============================================================================
#                 ServeHub-2: ШАБЛОН КОНФИГУРАЦИИ SECRETS.YML
# ==============================================================================
# Инструкция: Скопируйте этот файл под именем secrets.yml:
# cp secrets.yml.example secrets.yml
# Отредактируйте все значения на реальные.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. СЕТЕВАЯ ИНФРАСТРУКТУРА И ПОЛЬЗОВАТЕЛИ
# ------------------------------------------------------------------------------
# Публичный статический IPv4-адрес вашего внешнего арендованного VPS
# Для тестирования с Vagrant можно не прописывать, так как IP уже указаны в инвентаре
vps_public_ip: "your_vps_public_ip"

# Имя непривилегированного системного пользователя на VPS (для SSH и скриптов), либо если этого пользователя нет, он создастся автоматически с доступом к sudo
vps_user: "your_vps_username"

#Пароль root пользователя на удаленном сервере
vps_root_password: "your_vps_root_password"

# Приватный IPv4-адрес вашего локального сервера в домашней сети
# Для тестирования с Vagrant можно не прописывать, так как IP уже указаны в инвентаре
local_private_ip: "your_local_private_ip"

# Имя непривилегированного системного пользователя на локальном сервере, либо если этого пользователя нет, он создастся автоматически с доступом к sudo
local_user: "your_local_username"

#Пароль root пользователя на локальном сервере
local_root_password: "your_local_root_password"


# ------------------------------------------------------------------------------
# 2. ГЛОБАЛЬНЫЕ НАСТРОЙКИ И АДМИНИСТРИРОВАНИЕ
# ------------------------------------------------------------------------------
# Основной зарегистрированный домен проекта (например: frolovserver.ru)
# Используется как имя сервера Matrix (Synapse) и базовый хост для маршрутизации Nginx
synapse_server_name: "your_domain.ru"

# Имя учетной записи главного администратора для веб-интерфейсов и сервисов
# Автоматически применится при инициализации Synapse, Grafana, Nextcloud и др.
admin_user: "admin"

# Сложный глобальный пароль администратора для первого входа в разворачиваемые сервисы
admin_password: "change_this_to_a_very_strong_password"

# Ваш основной email. Используется Certbot для регистрации SSL и уведомлений об истечении сертификатов
email: "your_primary_email@gmail.com"


# ------------------------------------------------------------------------------
# 3. НАСТРОЙКИ SMTP (УВЕДОМЛЕНИЯ ПО ПОЧТЕ ДЛЯ GATUS / СЕРВИСОВ)
# ------------------------------------------------------------------------------
# Адрес почтового сервера исходящей почты (например: smtp.gmail.com или smtp.yandex.ru)
smtp_host: "smtp.gmail.com"

# Порт шифрования. ВАЖНО: 465 требует SSL, 587 требует STARTTLS
smtp_port: "465"

# Логин от почтового ящика, с которого будут отправляться алерты
smtp_user: "your_alerts_sender@gmail.com"

# Пароль приложения. ВАЖНО: Писать строго СЛИТНО, БЕЗ ПРОБЕЛОВ
# Создать для Gmail можно тут: https://myaccount.google.com/apppasswords
smtp_password: "your_16_digit_app_password"

# Адрес отправителя в заголовке письма (обычно совпадает со SMTP_USER)
smtp_from: "your_alerts_sender@gmail.com"

# Почтовый ящик получателя, куда будут приходить критические алерты и уведомления об аптайме
smtp_to: "your_personal_mailbox@mail.ru"


# ------------------------------------------------------------------------------
# 4. СЛУЖБА МОНИТОРИНГА И СИСТЕМНЫЙ БОТ MATRIX
# ------------------------------------------------------------------------------
# Уникальный логин для системного бота Alertmanager внутри вашего сервера Matrix
matrix_bot_username: "monitoring-bot"

# Пароль от учетной записи бота Matrix (задается при его регистрации)
matrix_bot_password: "strong_bot_password"

# Секретный токен для авторизации вебхуков между Alertmanager и matrix-alertmanager.
# Сгенерируйте случайную строку (например, через команду: openssl rand -hex 16)
monitoring_secret: "generate_random_hex_string"


# ------------------------------------------------------------------------------
# 5. ИНТЕГРАЦИЯ С DNS-ПРОВАЙДЕРОМ (АВТО-SSL)
# ------------------------------------------------------------------------------
# API-ключ от личного кабинета Webnames.ru. Необходим для DNS-01 проверки Certbot
# Позволяет выпускать и автоматически продлевать Wildcard-сертификаты (*.domain.ru)
webnames_apikey: "your_webnames_api_key_here"


# ------------------------------------------------------------------------------
# 6. НАСТРОЙКИ СУБД POSTGRESQL
# ------------------------------------------------------------------------------
# Названия баз данных, которые будут автоматически созданы в контейнере СУБД Postgres
postgres_db_nextcloud: "nextcloud"
postgres_db_synapse: "synapse"
postgres_db_vaultwarden: "vaultwarden"

# Имя суперпользователя (root) для управления кластером баз данных PostgreSQL
postgres_user: "postgres_master"

# Надежный и длинный пароль суперпользователя СУБД PostgreSQL
postgres_password: "postgres_master_secure_password"


# ------------------------------------------------------------------------------
# 7. СЕКРЕТЫ И КЛЮЧИ БЕЗОПАСНОСТИ СЕРВИСОВ
# ------------------------------------------------------------------------------
# Секретные ключи для Synapse (Matrix). Необходимы для подписи сессий, токенов и форм.
# Каждое значение ДОЛЖНО быть уникальной случайной строкой!
# Рекомендуется генерировать через: openssl rand -hex 32
synapse_registration_shared_secret: "generate_random_hex_string_1"
synapse_macaroon_secret_key: "generate_random_hex_string_2"
synapse_form_secret: "generate_random_hex_string_3"

# Пароль для входа в закрытую административную панель Vaultwarden (/admin).
# Позволяет управлять пользователями и инвайтами вашего личного менеджера паролей.
secret_vaultwarden_password: "vaultwarden_admin_panel_secure_password"

# Публичный SSH ключ вашего рабочего ПК для доступа к серверам
# (тот же ключ, что добавлен в ~/.ssh/authorized_keys на серверах)
ssh_public_key: "ssh_desktop_public_key_where_ansible_is_installed"